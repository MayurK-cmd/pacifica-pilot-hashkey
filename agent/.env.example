# Pacifica (required for trading)
PACIFICA_PRIVATE_KEY=<your base58 private key from Pacifica testnet>
PACIFICA_BASE_URL=https://test-api.pacifica.fi/api/v1
PACIFICA_API_KEY=

# Backend Auth (required for hosted agent)
JWT_TOKEN=<your JWT token from frontend after login>
BACKEND_URL=http://localhost:3001

# Elfa AI (optional - will use mock data if not set)
ELFA_API_KEY=<from Elfa AI hackathon dashboard>

# Google Gemini (required for AI decisions)
GEMINI_API_KEY=<from Google AI Studio>

# Trading config
TRADE_SYMBOLS=BTC,ETH
LOOP_INTERVAL_SECONDS=300
DRY_RUN=true
MAX_POSITION_USDC=50
STOP_LOSS_PCT=3.0
TAKE_PROFIT_PCT=6.0
MIN_CONFIDENCE=0.6
USE_BINANCE_KLINE_FALLBACK=true
